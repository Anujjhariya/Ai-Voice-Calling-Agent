# ── Groq (free) ──────────────────────────────
# Get from: console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Murf AI (TTS) ────────────────────────────
# Get from: murf.ai/api  ($10 free credit)
MURF_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (telephony) ───────────────────────
# Get from: twilio.com console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Exotel (telephony - alternative) ─────────
# Get from: exotel.com console
EXOTEL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXOTEL_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Calendar ───────────────────────────
# Download from: console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CREDENTIALS_FILE=credentials.json

# ── Your server URL ───────────────────────────
# Local testing: your ngrok URL (e.g. https://abc123.ngrok-free.app)
# Production: your Railway/Render URL
BASE_URL=https://your-url-here.ngrok-free.app
